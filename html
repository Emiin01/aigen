                particle.style.top = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 15 + 's';
                container.appendChild(particle);
            }
        }

        // Create crypto ticker - Solana focused
        function createTicker() {
            const ticker = document.getElementById('ticker');
            const cryptos = [
                { symbol: 'SOL', price: '$142.47', change: '+4.2%', up: true },
                { symbol: 'JUP', price: '$1.24', change: '+8.7%', up: true },
                { symbol: 'BONK', price: '$0.000028', change: '+12.3%', up: true },
                { symbol: 'JTO', price: '$3.87', change: '+2.1%', up: true },
                { symbol: 'PYTH', price: '$0.52', change: '-1.2%', up: false },
                { symbol: 'WEN', price: '$0.00012', change: '+15.4%', up: true },
                { symbol: 'RAY', price: '$2.14', change: '+3.8%', up: true },
                { symbol: 'ORCA', price: '$4.23', change: '+1.9%', up: true }
            ];

            const allCryptos = [...cryptos, ...cryptos];
            
            allCryptos.forEach(crypto => {
                const item = document.createElement('div');
                item.className = 'ticker-item';
                item.innerHTML = `
                    <span class="ticker-symbol">${crypto.symbol}</span>
                    <span class="ticker-price">${crypto.price}</span>
                    <span class="ticker-change ${crypto.up ? 'up' : 'down'}">${crypto.change}</span>
                `;
                ticker.appendChild(item);
            });
        }

        // Create hot tokens - NEW!
        function createTokenCards() {
            const container = document.getElementById('tokenGrid');
            const tokens = [
                { name: '$BONK', badge: 'HOT 🔥', volume: '+847%', liquidity: '$2.4M', holders: '12.4K', txns: '847' },
                { name: '$WIF', badge: 'NEW', volume: '+234%', liquidity: '$1.8M', holders: '8.2K', txns: '523' },
                { name: '$MYRO', badge: 'TRENDING', volume: '+127%', liquidity: '$890K', holders: '4.7K', txns: '312' },
                { name: '$SAMO', badge: 'HOT 🔥', volume: '+456%', liquidity: '$3.1M', holders: '15.8K', txns: '1.2K' }
            ];

            tokens.forEach(token => {
                const card = document.createElement('div');
                card.className = 'token-card';
                card.innerHTML = `
                    <div class="token-header">
                        <div class="token-name">${token.name}</div>
                        <div class="token-badge">${token.badge}</div>
                    </div>
                    <div class="token-stats">
                        <div class="token-stat">
                            <div class="token-stat-label">Volume 24h</div>
                            <div class="token-stat-value">${token.volume}</div>
                        </div>
                        <div class="token-stat">
                            <div class="token-stat-label">Liquidity</div>
                            <div class="token-stat-value">${token.liquidity}</div>
                        </div>
                        <div class="token-stat">
                            <div class="token-stat-label">Holders</div>
                            <div class="token-stat-value">${token.holders}</div>
                        </div>
                        <div class="token-stat">
                            <div class="token-stat-label">Txns/min</div>
                            <div class="token-stat-value">${token.txns}</div>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Animate counter numbers
        function animateCounters() {
            const counters = document.querySelectorAll('.stat-number[data-target]');
            counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-target'));
                const duration = 2000;
                const step = target / (duration / 16);
                let current = 0;

                const updateCounter = () => {
                    current += step;
                    if (current < target) {
                        counter.textContent = Math.floor(current).toLocaleString();
                        requestAnimationFrame(updateCounter);
                    } else {
                        counter.textContent = target.toLocaleString();
                    }
                };

                updateCounter();
            });
        }

        // Newsletter functions
        function closeNewsletter() {
            document.getElementById('newsletterPopup').classList.remove('show');
